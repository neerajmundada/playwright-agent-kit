# Copy this file to .env and fill in real values. Never commit .env.

# --- Application URLs ---
BASE_URL="https://your-app-under-test.example.com"
API_BASE_URL="https://petstore.swagger.io/v2"   # Swagger Petstore demo API used by tests/api

# --- Environment ---
NODE_ENV="development"          # development | staging | production | test
LOG_LEVEL="info"                # error | warn | info | http | debug | verbose | silly

# --- Test execution ---
TIMEOUT=10000
HEADLESS=false
WORKERS=

# --- Retry / resilience ---
MAX_RETRIES=2
RETRY_DELAY=1000

# --- CI/CD (populated automatically in pipelines) ---
CI=false
CI_COMMIT_SHA=
CI_BUILD_ID=

# --- Test filtering ---
TEST_TAGS=
SMOKE_TESTS_ONLY=false

# --- Reporting ---
REPORT_LEVEL="detailed"         # summary | detailed | verbose

# --- Security ---
SKIP_SSL_VERIFICATION=false     # DEV ONLY - never enable in staging/production
SECURE_MODE=true

# --- Artifacts ---
ARTIFACT_STORAGE_PATH=
