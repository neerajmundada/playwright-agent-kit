{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "incremental": true,
    "types": ["node", "playwright"]
  },
  "include": [
    "tests",
    "pages",
    "api",
    "fixtures",
    "utils",
    "scripts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "reports"]
}
